    c.channel_name,
    c.channel_type,
    s.total_campaigns,

    -- Budget vs spend
    s.total_budget,
    s.total_spend,
    round(
        (s.total_spend / nullif(s.total_budget, 0) * 100)::numeric, 1
    )                                           as budget_utilization_pct,

    -- Traffic metrics
    s.total_impressions,
    s.total_clicks,
    s.avg_ctr,

    -- Revenue metrics
    s.total_orders,
    s.total_revenue,
    s.avg_order_value,

    -- Performance metrics
    s.roas,
    s.conversion_rate,
    s.cost_per_order,

    -- Verdict column for dashboard
    case
        when s.roas >= 5    then 'Excellent'
        when s.roas >= 2    then 'Profitable'
        when s.roas >= 1    then 'Break Even'
        else                     'Loss Making'
    end                                         as performance_verdict

from channel_summary s
left join channels c on s.channel_id = c.channel_id
order by s.roas desc
  );
  
