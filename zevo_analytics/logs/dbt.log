  create  table "Zevo_analytics"."staging"."mart_instagram_deterioration__dbt_tmp"
  
  
    as
  
  (
    select
    year,
    total_campaigns,
    total_budget,
    total_spend,
    total_impressions,
    total_clicks,
    round((avg_ctr * 100)::numeric, 2)      as avg_ctr_pct,
    total_orders,
    total_revenue,
    avg_order_value,
    roas,
    conversion_rate,
    cost_per_order,
    case
        when year = 2023 then 'Baseline Year'
        when year = 2024 then 'Deterioration Year'
    end                                         as year_label,
    case
        when roas >= 1  then 'Profitable'
        else                 'Loss Making'
    end                                         as roas_verdict
from instagram_deterioration
order by year asc
  );
  
